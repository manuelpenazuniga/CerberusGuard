# =============================================================================
# CerberusGuard — .gitignore
# =============================================================================
# Keep the public repository clean: no secrets, no build artifacts, no private
# planning docs. If you add a new toolchain or framework, extend this file.

# -----------------------------------------------------------------------------
# Private planning & strategy (do NOT publish)
# -----------------------------------------------------------------------------
# The docs/ directory holds the original hackathon brief, the project
# definition (AGENTTRUST_PROJECT.md), the 5-day roadmap, and the seed
# README/CLAUDE drafts. They contain pre-launch strategy and are intentionally
# kept out of the public repo. Public-facing architecture & threat-model docs
# will live under a different path (e.g. `documentation/` or in the GitHub wiki).
docs/

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
**/.aws/
**/.ssh/
*.crt
*.cer

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
**/target/
**/*.rs.bk
*.pdb
Cargo.lock.bak

# -----------------------------------------------------------------------------
# Node.js / npm / pnpm / yarn
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
.next/
out/
dist/
build/
.turbo/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/cache/
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Go (for upstream Lobster Trap build artefacts if vendored under external/)
# -----------------------------------------------------------------------------
vendor/
*.test
*.out

# -----------------------------------------------------------------------------
# External / vendored upstream binaries (we build them locally, not commit)
# -----------------------------------------------------------------------------
external/

# -----------------------------------------------------------------------------
# CerberusGuard runtime data (collector DB, audit logs)
# -----------------------------------------------------------------------------
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.db
*.db-journal
/data/
/runs/
compiled/
audit.ndjson
**/audit.ndjson
/tmp/

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Local-only Claude Code config (per-user agent preferences)
# -----------------------------------------------------------------------------
.claude/settings.local.json
